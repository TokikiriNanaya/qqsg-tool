# ============================================
# 本地开发环境配置
# 使用方法：复制此文件为 .env 即可直接运行
#   cp .env.example .env
# ============================================

# 应用配置
APP_NAME = "QQ三国工具"
APP_VERSION = "1.0.0"
DEBUG = True

# 数据库配置（确保本地 MySQL 已创建 qqsg 数据库）
DATABASE_URL = "mysql+pymysql://root:root@localhost:3306/qqsg?charset=utf8mb4"

# JWT 配置
SECRET_KEY = "qqsg-dev-secret-key-2025"
ALGORITHM = "HS256"
ACCESS_TOKEN_EXPIRE_MINUTES = 1440
REFRESH_TOKEN_EXPIRE_DAYS = 7

# CORS 配置
ALLOWED_ORIGINS = ["http://localhost:9939"]
