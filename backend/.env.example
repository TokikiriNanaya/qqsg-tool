# 应用配置
APP_NAME = "QQ三国工具"
APP_VERSION = "1.0.0"
DEBUG = True

# 数据库配置
DATABASE_URL = "mysql+pymysql://root:password@localhost:3306/qqsg?charset=utf8mb4"

# JWT配置
SECRET_KEY = "your-secret-key-change-in-production"
ALGORITHM = "HS256"
ACCESS_TOKEN_EXPIRE_MINUTES = 30
REFRESH_TOKEN_EXPIRE_DAYS = 7

# CORS配置
ALLOWED_ORIGINS = ["http://localhost:9939", "http://localhost:3000"]
